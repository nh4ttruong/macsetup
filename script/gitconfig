#!/bin/zsh

# Git profile switcher
# Usage: ./gitconfig.sh <yourname> OR ./gitconfig.sh <company>

PROFILE=$1

if [ "$PROFILE" = "<yourname>" ]; then
    git config --local user.name "<yourname>"
    git config --local user.email "<yourmail>"
    echo "✅ Switched to git profile: <yourname>"

elif [ "$PROFILE" = "<company>" ]; then
    git config --local user.name "<company>"
    git config --local user.email "<companymail>"
    echo "✅ Switched to git profile: <company>"

else
    echo "⚠️ Unknown profile: $PROFILE"
    echo "Usage: $0 [<yourname>|<company>]"
    exit 1
fi